---
import type { Project } from "../data/projects";

interface Props {
  projects: Project[];
  tags: string[];
}

const { projects, tags } = Astro.props;
---

<section id="projects" class="section-shell" aria-labelledby="projects-title">
  <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Selected work</p>
      <h2 id="projects-title" class="mt-2 text-3xl font-semibold tracking-tight text-copy sm:text-4xl">
        Projects
      </h2>
      <p class="mt-3 max-w-2xl text-muted">
        A curated list of shipped products and in-flight experiments focused on clean UI, useful automation, and
        measurable outcomes.
      </p>
    </div>
  </div>

  <div class="mb-8 flex flex-wrap gap-2" aria-label="Filter projects by tag">
    {
      tags.map((tag, index) => (
        <button
          type="button"
          class="filter-chip"
          data-tag={tag.toLowerCase()}
          aria-pressed={index === 0 ? "true" : "false"}
          data-active={index === 0 ? "true" : "false"}
        >
          {tag}
        </button>
      ))
    }
  </div>

  <div data-projects class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    {
      projects.map((project) => (
        <article
          class="project-card card-lift rounded-2xl border border-card-border bg-card p-5"
          data-tags={project.tags.map((tag) => tag.toLowerCase()).join(",")}
        >
          <div class="mb-3 flex items-start justify-between gap-3">
            <h3 class="text-xl font-semibold text-copy">{project.title}</h3>
            <span
              class:list={[
                "rounded-full border px-2 py-1 text-xs font-medium",
                project.status === "Shipped"
                  ? "border-emerald-400/35 bg-emerald-400/10 text-emerald-300"
                  : "border-amber-400/40 bg-amber-400/10 text-amber-300"
              ]}
            >
              {project.status}
            </span>
          </div>

          <p class="text-sm leading-relaxed text-muted">{project.summary}</p>

          <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technology tags">
            {
              project.tags.map((tag) => (
                <li class="rounded-full border border-card-border px-2.5 py-1 text-xs text-muted">{tag}</li>
              ))
            }
          </ul>

          <div class="mt-6 flex flex-wrap items-center gap-2">
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noreferrer noopener"
              class="cta-ghost"
              aria-label={`Open ${project.title} source code on GitHub`}
            >
              GitHub
            </a>
            {
              project.liveUrl ? (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="cta-ghost"
                  aria-label={`Open ${project.title} live demo`}
                >
                  Live Demo
                </a>
              ) : (
                <span
                  class="inline-flex cursor-not-allowed rounded-full border border-card-border px-3 py-1.5 text-xs text-muted/70"
                  aria-label="No live demo available"
                >
                  Live Demo N/A
                </span>
              )
            }
          </div>
        </article>
      ))
    }
  </div>

  <p id="projects-empty" class="mt-6 hidden text-sm text-muted" aria-live="polite">
    No projects match the selected filter.
  </p>
</section>

<script is:inline>
  (() => {
    const filterButtons = Array.from(document.querySelectorAll(".filter-chip"));
    const cards = Array.from(document.querySelectorAll(".project-card"));
    const emptyState = document.getElementById("projects-empty");

    if (!filterButtons.length || !cards.length) return;

    const applyFilter = (activeTag) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const tags = card.getAttribute("data-tags") ?? "";
        const shouldShow = activeTag === "all" || tags.split(",").includes(activeTag);
        card.classList.toggle("hidden", !shouldShow);
        if (shouldShow) visibleCount += 1;
      });

      filterButtons.forEach((button) => {
        const isActive = button.getAttribute("data-tag") === activeTag;
        button.setAttribute("data-active", String(isActive));
        button.setAttribute("aria-pressed", String(isActive));
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const selectedTag = button.getAttribute("data-tag") ?? "all";
        applyFilter(selectedTag);
      });
    });
  })();
</script>
