<section id="contact" class="section-shell pb-16" aria-labelledby="contact-title">
  <div class="rounded-3xl border border-card-border bg-card p-6 sm:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Contact</p>
    <h2 id="contact-title" class="mt-2 text-3xl font-semibold tracking-tight text-copy sm:text-4xl">
      Let&apos;s build something useful.
    </h2>
    <p class="mt-3 max-w-2xl text-muted">
      If you need a focused product partner for your next release, send a short brief and timeline. I usually respond
      within one business day.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <a href="mailto:hello@yourbrand.dev" class="cta-primary">hello@yourbrand.dev</a>
      <button id="copy-email" type="button" class="cta-secondary" aria-describedby="copy-feedback">
        Copy email
      </button>
      <span id="copy-feedback" class="text-sm text-muted" aria-live="polite"></span>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const copyButton = document.getElementById("copy-email");
    const feedback = document.getElementById("copy-feedback");
    const email = "hello@yourbrand.dev";

    if (!copyButton || !feedback) return;

    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        feedback.textContent = "Email copied.";
      } catch {
        feedback.textContent = "Copy failed. Use hello@yourbrand.dev.";
      }
    });
  })();
</script>
