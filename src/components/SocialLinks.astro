---
interface Props {
  orientation?: "horizontal" | "vertical";
  className?: string;
}

const { orientation = "horizontal", className = "" } = Astro.props;

const links = [
  {
    label: "GitHub",
    href: "https://github.com/your-username",
    icon: "M12 2C6.475 2 2 6.474 2 12c0 4.421 2.865 8.17 6.839 9.494.5.092.683-.217.683-.483 0-.237-.009-.867-.014-1.701-2.782.604-3.369-1.342-3.369-1.342-.455-1.156-1.111-1.464-1.111-1.464-.909-.621.069-.609.069-.609 1.004.071 1.532 1.032 1.532 1.032.893 1.531 2.341 1.089 2.91.833.091-.647.35-1.089.636-1.339-2.221-.253-4.555-1.111-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.271.098-2.649 0 0 .839-.268 2.75 1.025A9.567 9.567 0 0 1 12 6.845a9.56 9.56 0 0 1 2.504.337c1.91-1.293 2.748-1.025 2.748-1.025.546 1.378.202 2.396.1 2.649.64.699 1.028 1.592 1.028 2.683 0 3.842-2.337 4.687-4.566 4.936.36.309.679.919.679 1.852 0 1.337-.012 2.417-.012 2.747 0 .268.18.579.688.481A10.004 10.004 0 0 0 22 12c0-5.526-4.477-10-10-10Z"
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/your-username",
    icon: "M6.94 8.5h3.13V19H6.94V8.5Zm1.57-4.9c1 0 1.81.8 1.81 1.79 0 .99-.81 1.79-1.81 1.79s-1.81-.8-1.81-1.79c0-.99.81-1.79 1.81-1.79ZM12.03 8.5h2.99v1.43h.04c.42-.79 1.44-1.62 2.97-1.62 3.18 0 3.77 2.09 3.77 4.81V19h-3.12v-5.2c0-1.24-.02-2.84-1.73-2.84-1.73 0-2 1.35-2 2.75V19h-3.12V8.5Z"
  },
  {
    label: "Email",
    href: "mailto:hello@yourbrand.dev",
    icon: "M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2.75-.25a.25.25 0 0 0-.25.25v.19l6.5 4.88 6.5-4.88v-.19a.25.25 0 0 0-.25-.25H5.75Zm12.75 3.56-5.75 4.31a1.25 1.25 0 0 1-1.5 0L5.5 10.06v7.19c0 .14.11.25.25.25h12.5a.25.25 0 0 0 .25-.25v-7.19Z"
  }
];

const wrapperClass =
  orientation === "vertical" ? "flex flex-col items-center gap-3" : "flex items-center gap-3";
---

<div class:list={[wrapperClass, className]} aria-label="Social links">
  {
    links.map((link) => (
      <a
        href={link.href}
        target={link.href.startsWith("http") ? "_blank" : undefined}
        rel={link.href.startsWith("http") ? "noreferrer noopener" : undefined}
        aria-label={link.label}
        class="icon-button rounded-full border border-card-border bg-card/70 p-2 text-copy transition hover:-translate-y-0.5 hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true" fill="currentColor">
          <path d={link.icon}></path>
        </svg>
      </a>
    ))
  }
</div>
